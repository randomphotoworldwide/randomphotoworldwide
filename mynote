## 🌐 Frontend Code (`index.html`)

```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Archive</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 40px 20px; background: #fdfdfd; color: #333; }
        .btn { background: #10b981; color: white; padding: 16px 32px; border-radius: 8px; font-weight: bold; cursor: pointer; display: inline-block; margin-top: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        #status { margin-top: 20px; font-size: 1.1em; font-weight: 500; }
    </style>
</head>
<body>
    <h2>Scan & Upload to Archive</h2>
    <input type="file" id="imageInput" accept="image/*" style="display: none;">
    <label for="imageInput" class="btn">Select Photo</label>
    <p id="status">Ready to upload</p>

    <script>
        document.getElementById('imageInput').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const status = document.getElementById('status');
            status.innerText = "Generating secure path...";

            try {
                // 1. Get the temporary, pre-verified link from your FastAPI backend
                const response = await fetch(`https://your-api.eu{encodeURIComponent(file.name)}`);
                const data = await response.json();

                status.innerText = "Uploading straight to European storage...";

                // 2. Use browser fetch to push the file directly to your European cloud storage
                const uploadResponse = await fetch(data.upload_url, {
                    method: 'PUT',
                    body: file,
                    headers: { 'Content-Type': file.type }
                });

                if (uploadResponse.ok) {
                    status.innerText = "✅ Uploaded successfully!";
                } else {
                    status.innerText = "❌ Upload failed. Please try again.";
                }
            } catch (err) {
                status.innerText = "❌ Connection error.";
            }
        });
    </script>
</body>
</html>
```

