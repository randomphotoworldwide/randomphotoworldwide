## 🐍 Backend Code (`main.py`)

```python
import uuid
from datetime import timedelta
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from minio import Minio

app = FastAPI()

# Allow your frontend website to talk to your backend API
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_methods=["*"])

# Connect directly to your European storage provider (e.g., Hetzner or Scaleway)
storage_client = Minio(
    "://your-eu-provider.com",  # Endpoint for Frankfurt/Paris data centers
    access_key="YOUR_EU_STORAGE_KEY",
    secret_key="YOUR_EU_STORAGE_SECRET",
    secure=True
)

BUCKET_NAME = "qr-image-archive"

@app.get("/get-upload-url")
def generate_upload_url(filename: str):
    # Generate a unique string to prevent files from overwriting each other
    unique_name = f"uploads/{uuid.uuid4()}-{filename}"
    
    # Generate a 15-minute temporary upload link
    url = storage_client.get_presigned_url(
        method="PUT",
        bucket_name=BUCKET_NAME,
        object_name=unique_name,
        expires=timedelta(minutes=15)
    )
    return {"upload_url": url, "file_path": unique_name}
```

